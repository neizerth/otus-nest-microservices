{
  "name": "otus-nest-microservices",
  "version": "1.0.0",
  "description": "Сквозной демо-проект микросервисов NestJS по вебинару OTUS",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build api-gateway && nest build users && nest build mailer && nest build hash",
    "build:gateway": "nest build api-gateway",
    "build:users": "nest build users",
    "build:mailer": "nest build mailer",
    "build:hash": "nest build hash",
    "start:redis": "docker compose up -d redis",
    "start:mailer": "nest start mailer --watch",
    "start:users": "nest start users --watch",
    "start:hash": "nest start hash --watch",
    "start:gateway": "nest start api-gateway --watch",
    "start:all": "npm run start:redis && concurrently -k -n mailer,users,hash,gateway -c blue,green,magenta,cyan \"npm run start:mailer\" \"npm run start:users\" \"npm run start:hash\" \"npm run start:gateway\"",
    "lint": "eslint \"{apps,libs}/**/*.ts\" --fix",
    "format": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\""
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.6",
    "@nestjs/platform-express": "^11.0.1",
    "ioredis": "^5.8.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^7.0.0",
    "concurrently": "^9.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
